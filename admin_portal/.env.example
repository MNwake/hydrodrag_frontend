# HydroDrags Admin Portal – Environment Variables
# Copy to .env.local and adjust as needed.

# Backend API base URL (no trailing slash)
# VITE_API_BASE_URL=

# Single admin account (env-based login; not backend auth)
# VITE_ADMIN_USERNAME=
# VITE_ADMIN_PASSWORD=

# Optional staff account: Events + Racers only; read-only event/racer edits; no matchup or speed controls.
# Staff login is disabled unless BOTH are set (non-empty).
# VITE_STAFF_USERNAME=
# VITE_STAFF_PASSWORD=

# Set to true to log failed login diagnostics in the browser console (production builds too, if baked in).
# Dev server always logs failed attempts. Never log passwords — only lengths and match flags.
# VITE_DEBUG_LOGIN=true

# When set, sent as X-Admin-Key on all admin API requests. Must match backend VITE_ADMIN_API_KEY.
# VITE_ADMIN_API_KEY=your-secret-key
